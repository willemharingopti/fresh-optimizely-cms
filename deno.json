{
  "nodeModulesDir": "auto",
  "tasks": {
    "bump": "deno run --allow-read --allow-write scripts/bump-version.ts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"],
      "exclude": ["react-no-danger"]
    },
    "exclude": ["_fresh"]
  },
  "fmt": {
    "exclude": ["_fresh", "**/*.svg"],
    "semiColons": false,
    "lineWidth": 320
  },
  "lock": false,
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@optimizely/cms-sdk": "npm:@optimizely/cms-sdk@2.1.0-beta.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "name": "@willemharingopti/fresh-optimizely-cms",
  "exports": {
    ".": "./mod.ts",
    "./preview/PreviewListener.tsx": "./preview/PreviewListener.tsx"
  },
  "version": "1.0.3",
  "license": "MIT"
}
